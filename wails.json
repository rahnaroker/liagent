{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "litagent",
  "outputfilename": "litagent",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "postBuildHooks": {
    "windows/*": "powershell -NoProfile -Command \"Copy-Item -Path ../../wallpaper -Destination . -Recurse -Force\"",
    "darwin/*": "cp -R ../../wallpaper .",
    "linux/*": "cp -R ../../wallpaper ."
  },
  "author": {
    "name": "",
    "email": ""
  }
}
